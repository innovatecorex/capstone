APP_NAME=EncryptEd
APP_ENV=local
APP_KEY=base64:GENERATED_BY_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Switch from SQLite to MySQL ──────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=encrypted_db
DB_USERNAME=root
DB_PASSWORD=

# ── Mail ────────────────────────────────────────────────
# LOCAL DEV (default): OTP is shown on-screen, emails written to storage/logs/laravel.log
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@encrypted.edu.ph"
MAIL_FROM_NAME="EncryptEd"

# ── PRODUCTION — swap to SendGrid SMTP ──────────────────
# Sign up free at https://sendgrid.com → Settings → API Keys → Create
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=YOUR_SENDGRID_API_KEY_HERE
# MAIL_ENCRYPTION=tls

# ── LOCAL GUI (Mailpit built into Laragon / visit http://localhost:8025) ──
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null

# ── Session / Cache ──────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# ── AES-256 Encryption Key for PII ──────────────────────
# This is Laravel's APP_KEY used by Crypt:: facade (AES-256-CBC)
# Run: php artisan key:generate   ← do this first after setup

# Injection defense: 'block' (production) or 'monitor' (development - logs only)
INJECTION_DEFENSE_MODE=block
